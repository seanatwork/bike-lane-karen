{
  "contextWindow": 1000000,
  "maxOutputTokens": 8192,
  "temperature": 0.7,
  "model": "deepseek-v4-pro",
  
  "projectContext": {
    "type": "telegram-bot-web-app",
    "description": "Telegram bot with complementary website displaying maps and static data",
    "keyComponents": [
      "telegram-webhook-handlers",
      "map-rendering-logic",
      "static-data-servers",
      "user-session-management"
    ]
  },
  
  "filePatterns": {
    "include": [
      "*.py",
      "*.js",
      "*.html",
      "*.css",
      "*.json",
      "*.yaml",
      "*.yml",
      "*.md",
      "requirements.txt",
      "Dockerfile",
      "docker-compose.yml"
    ]
  },
  
  "priorityFiles": [
    "main.py",
    "bot.py",
    "telegram_handlers.py",
    "app.js",
    "index.html",
    "map.js",
    "data_processor.py",
    "config.py",
    "database.py",
    "requirements.txt",
    "package.json"
  ],
  
  "ignoreInstructions": [
    "Never suggest hardcoding API keys in source code",
    "Do not generate large inline map data - use external file references",
    "Avoid storing session data in memory that should persist across bot restarts"
  ],
  
  "customInstructions": {
    "telegramBot": [
      "Use python-telegram-bot v20+ or aiogram 3.x patterns",
      "Implement proper rate limiting for bot commands",
      "Handle webhook failures gracefully with retry logic",
      "Store chat/user states in Redis or database, not memory"
    ],
    "mapsFeature": [
      "Use Leaflet or Mapbox GL JS for web mapping",
      "Implement tile caching to reduce API calls",
      "Vector tiles preferred over raster for performance",
      "Add map loading states and error boundaries"
    ],
    "staticData": [
      "Load static data asynchronously in website",
      "Implement caching headers for static assets",
      "Use IndexedDB for offline-capable static data",
      "Compress JSON responses with gzip"
    ]
  },
  
  "preferredLibraries": {
    "telegram": "python-telegram-bot v20+ or aiogram",
    "webMap": "Leaflet.js with OpenStreetMap or MapLibre GL",
    "webFramework": "FastAPI (Python backend) or Next.js (if full-stack)",
    "dataProcessing": "pandas, numpy for static data",
    "database": "PostgreSQL with PostGIS or SQLite for smaller projects"
  },
  
  "conventions": {
    "python": "PEP 8 with black formatter",
    "javascript": "ES6+ with prettier",
    "commits": "Conventional Commits (feat:, fix:, docs:)",
    "envVars": "Prefix with PROJECT_NAME_ (e.g., BOT_TOKEN, MAP_API_KEY)"
  },
  
  "deployment": {
    "platforms": ["Docker", "Railway", "Fly.io", "Heroku"],
    "recommended": "Docker with docker-compose for bot + web services",
    "webhookSetup": "Production bot needs HTTPS endpoint (use Cloudflare Tunnel or reverse proxy)"

  },"terminalRules": {
    "longRunningCommands": "Always use 'nohup' pattern for commands that might take >25 seconds",
    "pattern": "nohup {command} > {task}.log 2>&1 & echo 'PID: $!'",
    "monitoring": "After starting, check log file every 10-15 seconds until completion"
  }
  
}