# Austin 311 Bot — Environment Variables
# Copy this file to .env and fill in your values.

# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional: Austin Open Data app token (increases rate limits for Socrata-powered pages like
# crime maps, budget, court data, pulse, restaurants, and water conservation)
# Get one free at https://data.austintexas.gov/profile/edit/developer_settings
AUSTINAPIKEY=your_austin_api_key_here

# Optional: Open311 API key (increases rate limits for Open311-powered maps like
# graffiti, traffic, noise, parking, parks, bicycle, homeless, and 311 nearby)
# Get one from the City of Austin 311 API team
# OPEN311_API_KEY=your_open311_api_key_here

# Optional: Google Maps API key (required for /directory command - libraries & pools hours)
# Get one at https://developers.google.com/maps/documentation/places/web-service/get-api-key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: path to SQLite database (default: 311_categories.db in project root)
# DB_PATH=311_categories.db

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO